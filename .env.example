# Replace with your Sepolia RPC URL (e.g., from Alchemy or Infura)
SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Replace with your MetaMask Private Key (NEVER SHARE THIS)
PRIVATE_KEY=0xyour_private_key_here

# ============================================================
#  FLASH ARBITRAGE BOT CONFIGURATION
# ============================================================

# Ethereum Mainnet RPC URL (required for arbitrage bot)
MAINNET_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Flashbots authentication key — generate a random private key for this
# (NOT your main wallet key — just used to sign Flashbots API requests)
FLASHBOT_AUTH_KEY=0xYOUR_RANDOM_PRIVATE_KEY

# Deployed FlashArbitrage contract address (set after deployment)
ARBITRAGE_CONTRACT=0xYOUR_DEPLOYED_CONTRACT_ADDRESS

# Minimum profit threshold in wei (default: 0.005 ETH = 5000000000000000)
MIN_PROFIT_WEI=5000000000000000

# Etherscan API key (for contract verification)
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
